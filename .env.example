# Copy to .env for local overrides (not used on Render — set env vars in the dashboard).

# Required in production (Render blueprint generates this automatically)
# PB_SECRET_KEY=change-me-to-a-long-random-string

# PostgreSQL (Render injects DATABASE_URL when linked to a database)
# DATABASE_URL=postgresql://user:pass@host/db

# SQLite file location (local default: project directory; Render disk: /var/data)
# DATA_DIR=.

# Facility timezone
# PICKLEBALL_TIMEZONE=Asia/Manila
# PICKLEBALL_UTC_OFFSET_HOURS=8

# Treat as production locally (enables Secure cookies, requires PB_SECRET_KEY)
# ENVIRONMENT=production
